{
  "entities": {
    "User": {
      "title": "User",
      "description": "Developer profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "bio": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "githubUrl": { "type": "string" },
        "techStack": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "followersCount": { "type": "number" },
        "followingCount": { "type": "number" },
        "rankingPoints": { "type": "number" },
        "portfolioSummary": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "email"]
    },
    "Post": {
      "title": "Post",
      "description": "A developer post containing text and code snippets",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "codeSnippet": { "type": "string" },
        "language": { "type": "string" },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "content"]
    },
    "Project": {
      "title": "Project",
      "description": "Developer project showcase",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "githubRepo": { "type": "string" },
        "demoUrl": { "type": "string" },
        "techStack": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "title", "description"]
    },
    "ChatRoom": {
      "title": "Chat Room",
      "description": "Real-time chat room between developers",
      "type": "object",
      "properties": {
        "participants": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "Chat message",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "text"]
    },
    "Follow": {
      "title": "Follow",
      "description": "User follow relationship",
      "type": "object",
      "properties": {
        "followerId": { "type": "string" },
        "followingId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "recipientId": { "type": "string" },
        "senderId": { "type": "string" },
        "type": { "type": "string", "enum": ["like", "comment", "follow"] },
        "postId": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Public posts"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Project showcases"
    },
    "/chatRooms/{roomId}": {
      "schema": "ChatRoom",
      "description": "Chat rooms"
    },
    "/chatRooms/{roomId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a room"
    },
    "/follows/{followId}": {
      "schema": "Follow",
      "description": "Follow relationships"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    }
  }
}
